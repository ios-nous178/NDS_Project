set -e

pnpm typecheck

# 푸시되는 커밋들 중 DS 패키지를 만진 게 있으면
#   - react/icons/tokens/tailwind-preset 변경 → pnpm release:local (build + pack + docs)
#   - mcp 만 변경        → docs 버전 표만 sync
# 결과를 별도 "chore: rebuild" 커밋으로 묶어서 같이 푸시한다.
# (PR 없이 main 으로 직접 push 하는 흐름 → 받는 쪽이 옛 .tgz/메타를 install 하지 않도록)

ZERO=0000000000000000000000000000000000000000
NEEDS_PACK=0
NEEDS_DOCS=0
NEEDS_SMOKE=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # 브랜치 삭제는 무시
  if [ "$local_sha" = "$ZERO" ]; then
    continue
  fi

  if [ "$remote_sha" = "$ZERO" ]; then
    # 첫 푸시: 다른 remote 어디에도 없는 커밋만 = 이번에 푸시되는 범위
    range_args="$local_sha --not --remotes"
  else
    range_args="$remote_sha..$local_sha"
  fi

  changed=$(git log $range_args --name-only --pretty=format: 2>/dev/null || true)

  if echo "$changed" | grep -qE '^packages/(react|icons|tokens|tailwind-preset)/'; then
    NEEDS_PACK=1
  fi
  if echo "$changed" | grep -qE '^packages/(mcp|react|icons|tokens|tailwind-preset)/'; then
    NEEDS_DOCS=1
  fi
  # MCP 서버 코드/매니페스트/패킹 스크립트가 바뀌었으면 release-mcpb 워크플로우에
  # 들어가기 전에 로컬에서 server 부팅 + 핵심 tool 호출을 한 번 검증한다.
  if echo "$changed" | grep -qE '^(packages/mcp/(src|manifest\.json|catalog\.json)|scripts/(pack|smoke)-mcpb\.mjs)'; then
    NEEDS_SMOKE=1
  fi
done

if [ "$NEEDS_PACK" = "1" ]; then
  echo ""
  echo "🛠  DS 패키지 변경 감지 — local-packages/*.tgz 재빌드..."
  pnpm release:local
elif [ "$NEEDS_DOCS" = "1" ]; then
  echo ""
  echo "🛠  MCP 변경 감지 — docs 버전 표 동기화..."
  node scripts/sync-version-docs.mjs
fi

if [ "$NEEDS_PACK" = "1" ] || [ "$NEEDS_DOCS" = "1" ]; then
  pnpm exec prettier --write docs/HTML_MOCKUP_GUIDE.md docs/NUDGE_EAP_DS_MCP_USAGE.md
  pnpm exec markdownlint-cli2 --fix docs/HTML_MOCKUP_GUIDE.md docs/NUDGE_EAP_DS_MCP_USAGE.md
  git add -A local-packages docs/HTML_MOCKUP_GUIDE.md docs/NUDGE_EAP_DS_MCP_USAGE.md
  if git diff --cached --quiet; then
    echo "ⓘ 변경된 산출물 없음 — rebuild 커밋 스킵."
  else
    git commit --no-verify -m "chore: rebuild local-packages + sync docs"
    echo ""
    echo "✓ Rebuild 커밋이 추가되어 이번 푸시에 포함됩니다."
  fi
fi

if [ "$NEEDS_SMOKE" = "1" ]; then
  echo ""
  echo "🔥 MCP 변경 감지 — smoke test 실행 중..."
  pnpm smoke:mcp-source
fi
