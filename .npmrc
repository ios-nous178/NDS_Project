# Windows MAX_PATH(260자) 대응.
# pnpm 의 .pnpm 가상 스토어 디렉터리명은 해석된 peer 의존성을 전부 인코딩해서 길어진다.
# 특히 app-builder-lib@..._electron-builder-squirrel-windows@..._electron-_<hash> 는 119자라
# GitHub Windows runner(D:\a\<repo>\<repo>\...)에서 NSIS makensis.exe 가 include 파일을
# 여는 시점에 271자가 되어 MAX_PATH 를 넘겨 `could not open file` 로 패키징이 실패했다.
# 디렉터리명 상한을 낮춰 경로를 260자 아래로 유지한다(잘린 이름 뒤에 해시가 붙어 충돌 없음).
virtual-store-dir-max-length=50
