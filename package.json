{
  "name": "nudge-design-system",
  "private": true,
  "version": "0.0.3",
  "description": "Nudge Design System monorepo",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": "24.x"
  },
  "volta": {
    "node": "24.0.0",
    "pnpm": "9.6.0"
  },
  "pnpm": {
    "overrides": {
      "node-gyp": "^12.2.0"
    }
  },
  "scripts": {
    "generate:component-guides": "node scripts/generate-component-guides.mjs",
    "generate:brand-coverage": "node scripts/generate-brand-coverage.mjs",
    "generate:guide-docs": "node scripts/generate-guide-docs.mjs",
    "generate:ssot": "turbo build --filter=@nudge-design/mcp^... --output-logs=errors-only && pnpm --filter @nudge-design/mcp build && pnpm generate:component-guides && pnpm generate:brand-coverage && pnpm generate:guide-docs",
    "generate:mcp-tools": "node scripts/generate-mcp-tools-reference.mjs",
    "lint:mcp-tools": "node scripts/generate-mcp-tools-reference.mjs --check",
    "generate:tokens": "node scripts/sync-tokens.mjs --write && pnpm --filter=@nudge-design/tokens build",
    "lint:tokens": "node scripts/sync-tokens.mjs --check",
    "sync:docs": "node scripts/sync-version-docs.mjs",
    "lint:docs": "node scripts/sync-version-docs.mjs --check",
    "sync:mcpb-version": "node scripts/sync-mcpb-version.mjs",
    "lint:mcpb-version": "node scripts/sync-mcpb-version.mjs --check",
    "lint:mcp-catalog": "node scripts/check-mcp-catalog.mjs",
    "lint:mirror-parity": "node scripts/check-mirror-parity.mjs",
    "lint:mirror-parity:update": "node scripts/check-mirror-parity.mjs --update",
    "lint:input-focus": "node scripts/check-input-tests.mjs",
    "lint:actions-layout": "node scripts/check-actions-layout.mjs",
    "lint:brand-completeness": "node scripts/check-brand-completeness.mjs",
    "lint:component-attrs": "node packages/html/scripts/generate-component-attrs.mjs --check",
    "lint:runtime-registry": "node scripts/check-runtime-registry.mjs",
    "lint:ssot": "node scripts/check-ssot.mjs",
    "fix": "node scripts/fix-all.mjs",
    "precommit": "node scripts/precommit-gate.mjs",
    "sync:skills": "node scripts/sync-skills.mjs",
    "lint:skills": "node scripts/sync-skills.mjs --check",
    "pack:local": "node scripts/pack-local-packages.mjs",
    "pack:local:no-build": "node scripts/pack-local-packages.mjs --no-build",
    "pack:mcpb": "node scripts/pack-mcpb.mjs",
    "pack:mcpb:no-build": "node scripts/pack-mcpb.mjs --no-build",
    "smoke:mcpb": "node scripts/smoke-mcpb.mjs",
    "smoke:mcp-source": "pnpm --filter @nudge-design/mcp build && node scripts/smoke-mcpb.mjs --source",
    "release:local": "node scripts/pack-local-packages.mjs && node scripts/sync-version-docs.mjs",
    "release-notes": "node scripts/generate-friendly-changelog.mjs",
    "release-notes:dry": "node scripts/generate-friendly-changelog.mjs --dry-run",
    "build": "turbo build --output-logs=errors-only",
    "dev": "turbo dev",
    "lint": "turbo lint --output-logs=errors-only && pnpm lint:ssot && pnpm lint:actions-layout && pnpm lint:input-tokens && pnpm lint:runtime-registry && markdownlint-cli2 \"docs/**/*.md\" && node scripts/sync-version-docs.mjs --check && node scripts/sync-mcpb-version.mjs --check && node scripts/sync-tokens.mjs --check && node scripts/generate-mcp-tools-reference.mjs --check && node scripts/sync-skills.mjs --check",
    "lint:design": "npx @google/design.md lint DESIGN.md",
    "export:tailwind": "npx @google/design.md export --format tailwind DESIGN.md",
    "export:dtcg": "npx @google/design.md export --format dtcg DESIGN.md",
    "lint:fix": "eslint . --fix && prettier --write . && markdownlint-cli2 --fix \"docs/**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "turbo dev --filter=@nudge-design/storybook",
    "storybook:start": "pnpm --filter @nudge-design/storybook build && node scripts/serve-storybook-static.mjs",
    "docs:dev": "turbo dev --filter=@nudge-design/docs",
    "docs:build": "turbo build --filter=@nudge-design/docs --output-logs=errors-only",
    "test": "turbo test --output-logs=errors-only",
    "typecheck": "turbo typecheck --output-logs=errors-only",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-mcpb-version.mjs && node scripts/sync-version-docs.mjs",
    "lint-staged": "lint-staged",
    "prepare": "test -d .git && husky || true",
    "lint:input-tokens": "node scripts/check-input-token-binding.mjs"
  },
  "prebuild": "pnpm generate:ssot",
  "predev": "pnpm generate:ssot",
  "predocs:dev": "pnpm generate:ssot",
  "predocs:build": "pnpm generate:ssot",
  "prestorybook": "pnpm generate:ssot",
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.27.0",
    "@google/design.md": "^0.1.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.32.0",
    "yaml": "^2.8.3"
  }
}
