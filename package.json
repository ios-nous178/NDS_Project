{
  "name": "nudge-eap-design-system",
  "private": true,
  "version": "0.1.8",
  "description": "NudgeEAP Design System monorepo",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": "24.x"
  },
  "volta": {
    "node": "24.0.0",
    "pnpm": "9.6.0"
  },
  "scripts": {
    "generate:component-inventory": "node scripts/generate-component-inventory.mjs",
    "generate:component-guides": "node scripts/generate-component-guides.mjs",
    "generate:guide-docs": "node scripts/generate-guide-docs.mjs",
    "generate:tokens": "node scripts/sync-tokens.mjs --write && pnpm --filter=@nudge-eap/tokens build",
    "lint:tokens": "node scripts/sync-tokens.mjs --check",
    "sync:docs": "node scripts/sync-version-docs.mjs",
    "lint:docs": "node scripts/sync-version-docs.mjs --check",
    "sync:mcpb-version": "node scripts/sync-mcpb-version.mjs",
    "lint:mcpb-version": "node scripts/sync-mcpb-version.mjs --check",
    "lint:mcp-catalog": "node scripts/check-mcp-catalog.mjs",
    "pack:local": "node scripts/pack-local-packages.mjs",
    "pack:local:no-build": "node scripts/pack-local-packages.mjs --no-build",
    "pack:mcpb": "node scripts/pack-mcpb.mjs",
    "pack:mcpb:no-build": "node scripts/pack-mcpb.mjs --no-build",
    "smoke:mcpb": "node scripts/smoke-mcpb.mjs",
    "smoke:mcp-source": "pnpm --filter @nudge-eap/mcp build && node scripts/smoke-mcpb.mjs --source",
    "release:local": "node scripts/pack-local-packages.mjs && node scripts/sync-version-docs.mjs",
    "release-notes": "node scripts/generate-friendly-changelog.mjs",
    "release-notes:dry": "node scripts/generate-friendly-changelog.mjs --dry-run",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint && markdownlint-cli2 \"docs/**/*.md\" && node scripts/sync-version-docs.mjs --check && node scripts/sync-mcpb-version.mjs --check",
    "lint:design": "npx @google/design.md lint DESIGN.md",
    "export:tailwind": "npx @google/design.md export --format tailwind DESIGN.md",
    "export:dtcg": "npx @google/design.md export --format dtcg DESIGN.md",
    "lint:fix": "eslint . --fix && prettier --write . && markdownlint-cli2 --fix \"docs/**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "turbo dev --filter=@nudge-eap/storybook",
    "docs:dev": "turbo dev --filter=@nudge-eap/docs",
    "docs:build": "turbo build --filter=@nudge-eap/docs",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-mcpb-version.mjs && node scripts/sync-version-docs.mjs",
    "lint-staged": "lint-staged",
    "prepare": "test -d .git && husky || true"
  },
  "prebuild": "pnpm generate:component-inventory && pnpm generate:component-guides",
  "predev": "pnpm generate:component-inventory && pnpm generate:component-guides",
  "predocs:dev": "pnpm generate:component-inventory && pnpm generate:component-guides",
  "predocs:build": "pnpm generate:component-inventory && pnpm generate:component-guides",
  "prestorybook": "pnpm generate:component-inventory && pnpm generate:component-guides",
  "prelint": "pnpm generate:component-inventory && pnpm generate:component-guides",
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.27.0",
    "@google/design.md": "^0.1.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.32.0",
    "yaml": "^2.8.3"
  }
}
