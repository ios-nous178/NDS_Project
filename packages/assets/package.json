{
  "name": "@nudge-design/assets",
  "version": "0.0.3",
  "description": "Raster/vector brand assets (logos) for Nudge Design System — single SSOT, brand-swap interface, base64 fallback for zero-config consumers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./brand-logos": {
      "types": "./dist/brand-logos/index.d.ts",
      "import": "./dist/brand-logos/index.js"
    },
    "./brand-logo-metadata": {
      "types": "./dist/brand-logo-metadata.d.ts",
      "import": "./dist/brand-logo-metadata.js"
    },
    "./brand-logo-defaults": {
      "types": "./dist/brand-logo-defaults.d.ts",
      "import": "./dist/brand-logo-defaults.js"
    },
    "./sns-logos": {
      "types": "./dist/sns-logo-manifest.d.ts",
      "import": "./dist/sns-logo-manifest.js"
    },
    "./sns-logo-metadata": {
      "types": "./dist/sns-logo-metadata.d.ts",
      "import": "./dist/sns-logo-metadata.js"
    },
    "./sns-logo-defaults": {
      "types": "./dist/sns-logo-defaults.d.ts",
      "import": "./dist/sns-logo-defaults.js"
    },
    "./profile-images": {
      "types": "./dist/profile-image-metadata.d.ts",
      "import": "./dist/profile-image-metadata.js"
    },
    "./illustrations": {
      "types": "./dist/illustration-metadata.d.ts",
      "import": "./dist/illustration-metadata.js"
    },
    "./marathon-events": {
      "types": "./dist/marathon-event-metadata.d.ts",
      "import": "./dist/marathon-event-metadata.js"
    },
    "./nudge-img": {
      "types": "./dist/nudge-img-metadata.d.ts",
      "import": "./dist/nudge-img-metadata.js"
    },
    "./files/*": "./dist/files/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && node scripts/copy-files.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
