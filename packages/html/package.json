{
  "name": "@nudge-design/html",
  "version": "0.0.1",
  "description": "Vanilla Web Components for Nudge Design System — framework-agnostic DOM elements that pair with @nudge-design/styles.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./styles.css": "./dist/styles.css",
    "./standalone/*": "./dist/standalone/*",
    "./elements/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/runtime.js",
    "./dist/components/*.js"
  ],
  "scripts": {
    "build": "node ../../scripts/check-runtime-registry.mjs && rm -rf dist && tsc && node scripts/copy-styles.mjs && node scripts/build-standalone.mjs",
    "build:fixture": "node test-fixture/build-fixture.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nudge-design/assets": "workspace:*",
    "@nudge-design/icons": "workspace:*",
    "@nudge-design/styles": "workspace:*",
    "@nudge-design/tokens": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
