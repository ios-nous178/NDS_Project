{
  "name": "@nudge-eap/mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the NudgeEAP Design System (components, icons, tokens, mockup validator)",
  "type": "module",
  "bin": {
    "nudge-eap-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "scripts",
    "manifest.json",
    "catalog.json"
  ],
  "scripts": {
    "build:manifest": "node scripts/emit-manifest.mjs",
    "build": "pnpm run build:manifest && tsc",
    "start": "node dist/server.js",
    "dev": "pnpm run build:manifest && tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/types": "^7.25.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@nudge-eap/tokens": "workspace:*",
    "@nudge-eap/react": "workspace:*",
    "@nudge-eap/icons": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
