{
  "name": "@nudge-design/mockup-core",
  "version": "0.0.1",
  "description": "Deterministic mockup engine shared by the Nudge DS MCP server and the desktop harness (HTML build, DS-wrap, validation, usage tracking).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tools/*": {
      "types": "./dist/tools/*.d.ts",
      "default": "./dist/tools/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/types": "^7.25.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0"
  }
}
