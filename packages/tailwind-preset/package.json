{
  "name": "@nudge-eap/tailwind-preset",
  "version": "0.1.10",
  "description": "Tailwind CSS preset for NudgeEAP Design System",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nudge-eap/tokens": "workspace:*"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
