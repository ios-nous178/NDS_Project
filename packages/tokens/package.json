{
  "name": "@nudge-eap/tokens",
  "version": "0.1.5",
  "description": "Design tokens for NudgeEAP Design System",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./brands": {
