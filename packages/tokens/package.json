{
  "name": "@nudge-design/tokens",
  "version": "0.0.3",
  "description": "Design tokens for Nudge Design System",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./brands": {
      "types": "./dist/brands/index.d.ts",
      "import": "./dist/brands/index.js",
      "default": "./dist/brands/index.js"
    },
    "./brand-profiles": {
      "types": "./dist/brand-profiles.d.ts",
      "import": "./dist/brand-profiles.js",
      "default": "./dist/brand-profiles.js"
    },
    "./css": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/tokens.css"
    },
    "./css/trost": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/trost.css"
    },
    "./css/geniet": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/geniet.css"
    },
    "./css/cashwalk-biz": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/cashwalk-biz.css"
    },
    "./css/runmile": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/runmile.css"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/generate-css.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "type": "module"
}
