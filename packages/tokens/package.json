{
  "name": "@nudge-design/tokens",
  "version": "0.0.4",
  "description": "Design tokens for Nudge Design System",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./projects": {
      "types": "./dist/projects/index.d.ts",
      "import": "./dist/projects/index.js",
      "default": "./dist/projects/index.js"
    },
    "./project-profiles": {
      "types": "./dist/project-profiles.d.ts",
      "import": "./dist/project-profiles.js",
      "default": "./dist/project-profiles.js"
    },
    "./css": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/tokens.css"
    },
    "./css/trost": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/trost.css"
    },
    "./css/geniet": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/geniet.css"
    },
    "./css/cashwalk-biz": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/cashwalk-biz.css"
    },
    "./css/runmile": {
      "types": "./dist/css-stub.d.ts",
      "default": "./dist/runmile.css"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/generate-css.cjs && node scripts/generate-next.cjs && node scripts/build-figma-plugin.cjs",
    "check:value-freeze": "node scripts/check-value-freeze.cjs",
    "figma:variables": "node scripts/figma-variables-upload.cjs",
    "figma:plugin": "node scripts/build-figma-plugin.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "type": "module"
}
