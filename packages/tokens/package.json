{
  "name": "@nudge-design/tokens",
  "version": "0.0.2",
  "description": "Design tokens for Nudge Design System",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./brands": {
      "types": "./dist/brands/index.d.ts",
      "import": "./dist/brands/index.js"
    },
    "./css": "./dist/tokens.css",
    "./css/trost": "./dist/trost.css",
    "./css/geniet": "./dist/geniet.css",
    "./css/cashwalk-biz": "./dist/cashwalk-biz.css",
    "./css/runmile": "./dist/runmile.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/generate-css.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
